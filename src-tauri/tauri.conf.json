{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "살핌",
  "version": "1.0.0",
  "identifier": "com.shinchang.salpeem",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "살핌",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/shinnanchanguk/salpeeem-releases/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDQ1RDQ4RkRGMDc1MjBGOEYKUldTUEQxSUgzNC9VUmNtdkNpY3RDM2tPdVlJNG5RQjhkWU1VZlZWWllicEdtRU4yOFViWkdVU1kK"
    }
  }
}
